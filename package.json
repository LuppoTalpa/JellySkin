{
	"name": "@luppodev/jellyskin",
	"version": "12.5.6",
	"description": "A vibrant skin for jellyfin made with SASS",
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"/dist"
	],
	"main": "/dist/main.css",
	"scripts": {
		"watch:sass": "sass --watch src/:dev/ src/addons/:dev/addons/",
		"serve": "browser-sync start --server --files 'dev' 'src'",
		"build": "sass src/:dist/ src/addons/:dist/addons/",
		"postbuild": "postcss dist/*.css -u autoprefixer cssnano -r",
		"start": "npm-run-all2 --parallel watch:sass serve",
		"pub:prerelease": "np prerelease --no-tests --tag nightly --branch master",
		"pub:patch": "np patch --no-tests --tag latest --branch master",
		"pub:minor": "np minor --no-tests --tag latest --branch master",
		"pub:major": "np major --no-tests --tag latest --branch master",
		"lint:style": "stylelint \"src/**/*.scss\" --fix",
		"format": "prettier --write \"src/**/*.{scss,css,json}\""
	},
	"np": {
		"yarn": false,
		"anyBranch": true
	},
	"devDependencies": {
		"autoprefixer": "^10.4.21",
		"browser-sync": "^3.0.3",
		"copyfiles": "^2.4.1",
		"cssnano": "^7.0.7",
		"np": "^10.2.0",
		"npm-run-all2": "^7.0.2",
		"onchange": "^7.1.0",
		"postcss-cli": "^11.0.1",
		"prettier": "^3.5.3",
		"sass": "^1.86.0",
		"stylelint": "^16.18.0",
		"stylelint-config-standard-scss": "^14.0.0"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/luppodev/JellySkin.git"
	},
	"keywords": [
		"jellyfin",
		"css",
		"jellyskin"
	],
	"author": "luppodev",
	"license": "GPL-3.0-only",
	"bugs": {
		"url": "https://github.com/luppodev/JellySkin/issues"
	},
	"homepage": "https://github.com/luppodev/JellySkin#readme"
}
